{
    "name": "ekrouzek/pagination-filters-bundle",
    "description": "Filtering, sorting and pagination bundle for paginated http requests.",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.0.1",
        "nette/utils": "^3.2",
        "friendsofsymfony/rest-bundle": "^3.3",
        "doctrine/orm": "^2.11",
        "symfony/uid": "^5.4 || ^6.0 || ^7.0",
        "nesbot/carbon": "^3.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-doctrine": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Ekrouzek\\PaginationFiltersBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ekrouzek\\PaginationFiltersBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=1G"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Vojtěch Bešťák",
            "homepage": "https://ekrouzek.cz"
        }
    ]
}
